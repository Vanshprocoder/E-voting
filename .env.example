# Copy this file to `.env` in the same folder as package.json and fill in values
# from Firebase Console → Project settings → Your apps → SDK setup & configuration.
#
# Realtime Database URL: Realtime Database → top of Data tab
#   Example: https://YOUR_PROJECT_ID-default-rtdb.firebaseio.com
#   Or regional: https://YOUR_PROJECT_ID-default-rtdb.REGION.firebasedatabase.app

VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
VITE_FIREBASE_MEASUREMENT_ID=

# Required for Realtime Database — must match your database URL
VITE_FIREBASE_DATABASE_URL=
